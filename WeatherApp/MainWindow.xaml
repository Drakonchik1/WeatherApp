<Window x:Class="WeatherApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WeatherApp"
        mc:Ignorable="d"
        Title="Weather App - OpenWeatherMap and IMGW" Height="850" Width="1200"
        Loaded="Window_Loaded"
        Background="#F0F8FF">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        
        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#2196F3" Padding="20">
            <StackPanel>
                <TextBlock Text="Weather Application" 
                          FontSize="24" 
                          FontWeight="Bold" 
                          Foreground="White" 
                          HorizontalAlignment="Center"/>
                <TextBlock Text="OpenWeatherMap and IMGW Integration" 
                          FontSize="14" 
                          Foreground="White" 
                          HorizontalAlignment="Center" 
                          Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Input Section -->
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <GroupBox Header="Weather Search" FontWeight="Bold" Margin="0,0,0,20">
                    <StackPanel Margin="10">
                        <TextBlock Text="Enter city name:" FontWeight="Bold"/>
                        <ComboBox x:Name="CityComboBox"
                                  IsEditable="True"
                                  StaysOpenOnEdit="True"
                                  IsTextSearchEnabled="False"
                                  Height="35"
                                  MaxDropDownHeight="300"
                                  Text="Warsaw"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button x:Name="OpenWeatherButton" 
                                   Content="Get OpenWeatherMap Data" 
                                   Click="OpenWeatherButton_Click"
                                   Background="#FF9800"/>
                            <Button x:Name="ImgwButton" 
                                   Content="Get IMGW Data" 
                                   Click="ImgwButton_Click"
                                   Background="#9C27B0"/>
                        </StackPanel>
                        
                        <Button x:Name="ShowDashboardButton" 
                               Content="Show Weather Dashboard" 
                               Click="ShowDashboardButton_Click"
                               Background="#607D8B"
                               Margin="0,10,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- Current Weather Display -->
                <GroupBox Header="Current Weather" FontWeight="Bold">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400">
                        <StackPanel x:Name="WeatherDisplayPanel" Margin="10">
                            <TextBlock Text="Select a data source to view weather information" 
                                      FontStyle="Italic" 
                                      Foreground="Gray" 
                                      HorizontalAlignment="Center" 
                                      Margin="0,50"/>
                        </StackPanel>
                    </ScrollViewer>
                </GroupBox>
            </StackPanel>

            <!-- Weather Data Table -->
            <GroupBox Grid.Column="1" Header="Weather Data Table" FontWeight="Bold" Margin="10,0,0,0">
                <DataGrid x:Name="WeatherDataGrid" 
                         AutoGenerateColumns="False" 
                         CanUserAddRows="False" 
                         CanUserDeleteRows="False"
                         IsReadOnly="True"
                         GridLinesVisibility="Horizontal"
                         HeadersVisibility="Column"
                         Margin="10">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="120"/>
                        <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="150"/>
                        <DataGridTextColumn Header="Temperature (°C)" Binding="{Binding Temperature, StringFormat=F1}" Width="100"/>
                        <DataGridTextColumn Header="Humidity (%)" Binding="{Binding Humidity, StringFormat=F1}" Width="100"/>
                        <DataGridTextColumn Header="Pressure (hPa)" Binding="{Binding Pressure, StringFormat=F1}" Width="100"/>
                        <DataGridTextColumn Header="Cloudiness (%)" Binding="{Binding Cloudiness, StringFormat=F1}" Width="100"/>
                        <DataGridTextColumn Header="Rainfall (mm)" Binding="{Binding Rainfall, StringFormat=F1}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#E0E0E0" Padding="10">
            <TextBlock x:Name="StatusText" Text="Ready" FontSize="12"/>
        </Border>
    </Grid>
</Window>
