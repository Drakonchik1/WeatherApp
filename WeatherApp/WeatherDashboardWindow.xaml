<Window x:Class="WeatherApp.WeatherDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WeatherApp"
        mc:Ignorable="d"
        Title="Weather Dashboard" Height="800" Width="1200"
        Background="#F5F5F5">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1976D2" Padding="20">
            <StackPanel>
                <TextBlock Text="Weather Analytics Dashboard" 
                          FontSize="24" 
                          FontWeight="Bold" 
                          Foreground="White" 
                          HorizontalAlignment="Center"/>
                <TextBlock Text="Data Visualization and Reports" 
                          FontSize="14" 
                          Foreground="White" 
                          HorizontalAlignment="Center" 
                          Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Control Panel -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Pick date:" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <DatePicker x:Name="DateFilterPicker" SelectedDateChanged="DateFilterPicker_SelectedDateChanged" Width="150"/>
                </StackPanel>
                <Button x:Name="GenerateSamplesButton"
                        Content="Load 10 samples"
                        Click="GenerateSamplesButton_Click"
                        Background="#3F51B5"/>
                <Separator Width="20"/>
                <Button x:Name="TemperatureChartButton" 
                       Content="Temperature Chart" 
                       Click="TemperatureChartButton_Click"
                       Background="#FF5722"/>
                <Button x:Name="HumidityChartButton" 
                       Content="Humidity Chart" 
                       Click="HumidityChartButton_Click"
                       Background="#4CAF50"/>
                <Button x:Name="PressureChartButton" 
                       Content="Pressure Chart" 
                       Click="PressureChartButton_Click"
                       Background="#9C27B0"/>
                <Button x:Name="RainfallChartButton" 
                       Content="Rainfall Chart" 
                       Click="RainfallChartButton_Click"
                       Background="#00BCD4"/>
                <Button x:Name="CombinedChartButton" 
                       Content="Combined View" 
                       Click="CombinedChartButton_Click"
                       Background="#FF9800"/>
                <Button x:Name="ExportDataButton" 
                       Content="Export Data" 
                       Click="ExportDataButton_Click"
                       Background="#607D8B"/>
            </StackPanel>

            <!-- Chart Display Area -->
            <Border Grid.Row="1" 
                   Background="White" 
                   BorderBrush="#CCCCCC" 
                   BorderThickness="1" 
                   CornerRadius="5">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ChartPanel" Margin="20">
                        <TextBlock Text="Select a chart type to view weather analytics" 
                                  FontSize="16" 
                                  FontStyle="Italic" 
                                  Foreground="Gray" 
                                  HorizontalAlignment="Center" 
                                  Margin="0,50"/>
                        <TextBlock x:Name="SourceLabel" Text="" FontSize="12" Foreground="Gray" HorizontalAlignment="Center"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="#E0E0E0" Padding="10">
            <TextBlock x:Name="StatusText" Text="Ready" FontSize="12"/>
        </Border>
    </Grid>
</Window>
